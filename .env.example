SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Deployed Next.js on Vercel — must serve POST /api/payhere/hash + /api/location/*
# NOT the marketing nginx host (freshasever.com returns 405 on /api/payhere/hash).
API_BASE_URL=https://fresh-as-ever.vercel.app
# Optional: override return/cancel URLs for PayHere (https app link base)
# PAYHERE_RETURN_URL_HOST=https://app.freshasever.com
# Staging only: allow qa.admin@ / qa.merchant@ test accounts to map roles (never in production)
# ENABLE_QA_ROLE_OVERRIDES=1
# Staging only: autofill QA login (requires passwords below — set in local .env, never commit)
# EXPO_PUBLIC_QA_AUTOFILL_LOGIN=true
# EXPO_PUBLIC_QA_MERCHANT_EMAIL=qa.merchant@freshasever.test
# EXPO_PUBLIC_QA_CUSTOMER_PASSWORD=
# EXPO_PUBLIC_QA_MERCHANT_PASSWORD=
# Investor / design-review demo data (merchant payouts, promos, live monitor, disputes).
# Must be the literal string `true`. Omit or set to `false` for production behaviour.
# EXPO_PUBLIC_FAE_DEMO_MODE=true
# Multi-bag group reservations (outlet cart + create_group_reservation). Literal `true` enables.
# EXPO_PUBLIC_GROUP_RESERVATIONS_ENABLED=true

# Clearance Shelf (supermarket item-level listings). Literal `true` enables in prod builds.
# Unset defaults to enabled in local dev (`__DEV__`). Restart Metro after changing.
EXPO_PUBLIC_CLEARANCE_SHELVES_ENABLED=true

# iOS ATS: set to `0` to omit NSAllowsLocalNetworking in expo prebuild (release-hardening).
# EXPO_PUBLIC_ALLOW_LOCAL_NETWORKING=0

# Pass 26 — Sri Lanka expansion feature flags (default OFF until integration QA).
# Literal `true` enables. Restart Metro after changing.
EXPO_PUBLIC_PICKUP_WINDOW_PRESETS=false
EXPO_PUBLIC_LISTING_WHATSAPP_SHARE=false
EXPO_PUBLIC_NEIGHBOURHOOD_BROWSE=false
EXPO_PUBLIC_SEASONAL_BADGES=false
EXPO_PUBLIC_ON_MY_WAY=false
EXPO_PUBLIC_MONTHLY_SAVINGS_PUSH=false
# Google Maps SDK — required for branded Discover map tiles (iOS + Android).
# Restrict the key to bundle id `com.freshasever.mobile` in Google Cloud Console.
GOOGLE_MAPS_API_KEY=
# Sentry (react-native project, org flwstate-media-kx) — see docs/SENTRY_SETUP.md
SENTRY_DSN=https://f63e69dd93607ce7a203b1e5bfea0301@o4511443898466304.ingest.de.sentry.io/4511443919241296
